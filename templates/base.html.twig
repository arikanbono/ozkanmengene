<!DOCTYPE html>
<html lang="{{ app.request.locale|split('_')[0] }}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}"/>

    {% block meta %}
        {{ include('@SuluWebsite/Extension/seo.html.twig', {
            seo: extension.seo|default([]),
            content: content|default([]),
            localizations: localizations|default([]),
            shadowBaseLocale: shadowBaseLocale|default(),
        }) }}
    {% endblock %}

    {% block style %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body class="rs-smoother-yes">

    <header>
        {% block header %}
            {{ include('includes/common/header.html.twig') }}
        {% endblock %}
    </header>

    {#
    <form action="{{ path('sulu_search.website_search') }}" method="GET">
        <input name="q" type="text" placeholder="Search"/>
        <input type="submit" value="Go"/>
    </form>
    #}

    <main>
        {% block content %}{% endblock %}
    </main>

    <!-- footer area start -->
    {{ include('includes/common/footer.html.twig') }}
    <!-- footer area end -->

    <!-- back to top -->
    <!-- Backtotop start -->
    <div class="backtotop-wrap cursor-pointer">
        <svg class="backtotop-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
            <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
        </svg>
    </div>
    <!-- Backtotop end -->

    <!-- Contact Widget -->
    {% set contactSnippets = sulu_snippet_load_by_area('site_addresses') %}
    <div class="contact-widget">
        <input type="checkbox" id="contact-toggle">
        <label for="contact-toggle" class="contact-button">
            <i class="fa-brands fa-whatsapp"></i>
        </label>
        <div class="contact-popup">
            <div class="contact-popup-header">
                {{ 'contact_widget.title'|trans }}
            </div>
            <div class="contact-popup-content">
                <ul class="contact-list">
                    {% if contactSnippets.content.gsm %}
                    {% set gsmDigits = contactSnippets.content.gsm|phone_clean %}
                    {% if gsmDigits starts with '90' %}
                        {% set gsmForWa = gsmDigits %}
                    {% elseif gsmDigits starts with '0' %}
                        {% set gsmForWa = '90' ~ gsmDigits[1:] %}
                    {% else %}
                        {% set gsmForWa = '90' ~ gsmDigits %}
                    {% endif %}
                    <li>
                        <a href="https://wa.me/{{ gsmForWa }}" target="_blank">
                            <i class="fa-brands fa-whatsapp"></i>
                            <span>WhatsApp</span>
                        </a>
                    </li>
                    {% endif %}
                    {% if contactSnippets.content.phone %}
                    <li>
                        <a href="tel:+{{ contactSnippets.content.phone|phone_clean }}">
                            <i class="fa-solid fa-phone"></i>
                            <span>{{ contactSnippets.content.phone }}</span>
                        </a>
                    </li>
                    {% endif %}
                    <li>
                        <a href="{{ 'contact_widget.contact_path'|trans }}">
                            <i class="fa-regular fa-share-from-square"></i>
                            <span>{{ 'contact_widget.contact_form'|trans }}</span>
                        </a>
                    </li>
                    {% if contactSnippets.content.email %}
                    <li>
                        <a href="mailto:{{ contactSnippets.content.email }}">
                            <i class="fa-solid fa-envelope"></i>
                            <span>{{ contactSnippets.content.email }}</span>
                        </a>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </div>
    <!-- Contact Widget End -->

    {% block javascripts %}
        {# CSS is bundled via Encore; JS loaded as script tags for global scope compatibility #}
        {{ encore_entry_script_tags('app') }}

        {# --- Vendor JS --- #}
        <script src="{{ asset('build/website/js/vendor/jquery-3.7.1.min.js') }}"></script>
        <script src="{{ asset('build/website/js/vendor/bootstrap.bundle.min.js') }}"></script>
        <script src="{{ asset('build/website/js/vendor/magnific-popup.min.js') }}"></script>
        <script src="{{ asset('build/website/js/vendor/odometer.min.js') }}"></script>
        <script src="{{ asset('build/website/js/vendor/isotope.pkgd.min.js') }}"></script>
        <script src="{{ asset('build/website/js/vendor/imagesloaded.pkgd.min.js') }}"></script>
        <script src="{{ asset('build/website/js/vendor/purecounter.js') }}"></script>

        {# --- Plugin JS --- #}
        <script src="{{ asset('build/website/js/plugins/gsap.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/rs-scroll-trigger.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/rs-splitText.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/rs-anim-int.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/headding-title.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/swiper.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/wow.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/waypoints.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/jquery.appear.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/jquery.lettering.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/meanmenu.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/nice-select.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/nouislider.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/jarallax.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/marquee.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/parallax-effect.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/lenis.min.js') }}"></script>
        <script src="{{ asset('build/website/js/plugins/easypie.js') }}"></script>

        {# --- Main JS --- #}
        <script src="{{ asset('build/website/js/main.js') }}"></script>
    {% endblock %}
</body>
</html>
